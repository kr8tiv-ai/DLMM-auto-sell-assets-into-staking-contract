{
  "compilerOptions": {
    "types": ["node"],
    "typeRoots": ["../node_modules/@types"],
    "lib": ["es2020"],
    "module": "commonjs",
    "target": "es2020",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": false,
    "outDir": "../dist/scripts",
    "baseUrl": "..",
    "paths": {
      "*": ["*"]
    }
  },
  "include": ["./**/*.ts"],
  "references": []
}
