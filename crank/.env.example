# Brain Staking DLMM Exit Crank — Environment Variables
# Copy to .env and fill in required values.

# ── Required ──────────────────────────────────────────────

# Solana RPC endpoint (use a dedicated RPC for production)
SOLANA_RPC_URL=

# Path to the crank operator keypair JSON file
CRANK_KEYPAIR_PATH=

# Deployed brain-staking program ID (base58)
PROGRAM_ID=

# Staking pool PDA address (base58)
STAKING_POOL=

# Treasury address for emergency asset transfers
TREASURY_ADDRESS=

# ── Optional (defaults shown) ────────────────────────────

# Path to the Anchor IDL JSON file
# IDL_PATH=../target/idl/brain_staking.json

# Polling interval in milliseconds
# POLL_INTERVAL_MS=5000

# Minimum SOL fee threshold (lamports) before claiming
# CLAIM_THRESHOLD_LAMPORTS=1000000

# Jito block engine URL for MEV-protected bundles
# JITO_BLOCK_ENGINE_URL=https://mainnet.block-engine.jito.wtf

# Jito tip amount in lamports
# JITO_TIP_LAMPORTS=10000

# Enable dynamic tip fetching from Jito API (true/false)
# JITO_DYNAMIC_TIP=false

# Minimum tip when using dynamic tip (lamports)
# JITO_MIN_TIP_LAMPORTS=5000

# Metrics HTTP server port
# METRICS_PORT=9090

# Path to heartbeat file (written each monitor cycle)
# HEARTBEAT_PATH=./heartbeat.txt
